# RAG API (document ingestion and indexing)
RAG_API_BASE_URL=http://host.docker.internal:8000/api/v1

# LLM API (chat, quiz, presentation generation)
LLM_API_BASE_URL=http://host.docker.internal:8001

# ElevenLabs TTS API Key (for KI-Lehrer avatar speech)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# OpenAI API Key (for Whisper speech-to-text)
OPENAI_API_KEY=your_openai_key_here_for_whisper

# Gemini API Key (temporary onboarding language test generation)
GEMINI_API_KEY=your_gemini_key_here

# (Optional) Flask configuration
FLASK_ENV=development
FLASK_DEBUG=True
